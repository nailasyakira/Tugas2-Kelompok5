// SWAP

void swapInt(int *a, int *b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}

void swapStr(char a[], char b[]) {
    char temp[PANJANG_KATA];
    strcpy(temp, a);
    strcpy(a, b);
    strcpy(b, temp);
}

// DISPLAY

void tampilInt(int arr[], int n) {
    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");
}

void tampilStr(char arr[][PANJANG_KATA], int n) {
    for(int i = 0; i < n; i++) {
        printf("%s\n", arr[i]);
    }
}

// SHUFFLE

void shuffleInt(int arr[], int n) {
    for(int i = 0; i < n; i++) {
int j = rand() % n;
        swapInt(&arr[i], &arr[j]);
    }
}

void shuffleStr(char arr[][PANJANG_KATA], int n) {
    for(int i = 0; i < n; i++) {
        int j = rand() % n;
        swapStr(arr[i], arr[j]);
    }
}

// Bubble Sort
void bubbleSort(int arr[], int n) {
    for(int i = 0; i < n - 1; i++) {
        for(int j = 0; j < n - i - 1; j++) {
            if(arr[j] > arr[j + 1]) {
                swapInt(&arr[j], &arr[j + 1]);
            }
        }
    }
}

// Insertion Sort
void insertionSort(int arr[], int n) {
    for(int i = 1; i < n; i++) {

        int key = arr[i];
        int j = i - 1;

        while(j >= 0 && arr[j] > key) {
            arr[j + 1] = arr[j];
            j--;
        }

        arr[j + 1] = key;
    }
}

