// SHUFFLE

void shuffleInt(int arr[], int n) {
    for(int i = 0; i < n; i++) {
int j = rand() % n;
        swapInt(&arr[i], &arr[j]);
    }
}

void shuffleStr(char arr[][PANJANG_KATA], int n) {
    for(int i = 0; i < n; i++) {
        int j = rand() % n;
        swapStr(arr[i], arr[j]);
    }
}

// Bubble Sort
void bubbleSort(int arr[], int n) {
    for(int i = 0; i < n - 1; i++) {
        for(int j = 0; j < n - i - 1; j++) {
            if(arr[j] > arr[j + 1]) {
                swapInt(&arr[j], &arr[j + 1]);
            }
        }
    }
}

// Insertion Sort
void insertionSort(int arr[], int n) {
    for(int i = 1; i < n; i++) {

        int key = arr[i];
        int j = i - 1;

        while(j >= 0 && arr[j] > key) {
            arr[j + 1] = arr[j];
            j--;
        }

        arr[j + 1] = key;
    }
}

// Selection Sort
void selectionSort(int arr[], int n) {
    for(int i = 0; i < n - 1; i++) {

 int min = i;

        for(int j = i + 1; j < n; j++) {
            if(arr[j] < arr[min]) {
                min = j;
            }
        }

        swapInt(&arr[i], &arr[min]);
    }
}

