    for(int i = 0; i < n1; i++) {
        strcpy(L[i], arr[left + i]);
    }

    for(int j = 0; j < n2; j++) {
        strcpy(R[j], arr[mid + 1 + j]);
    }

    int i = 0;
    int j = 0;
    int k = left;

    while(i < n1 && j < n2) {

        if(strcmp(L[i], R[j]) <= 0) {
            strcpy(arr[k], L[i]);
            i++;
        } else {
            strcpy(arr[k], R[j]);
            j++;
        }

        k++;
    }

    while(i < n1) {
        strcpy(arr[k], L[i]);
        i++;
        k++;
    }

    while(j < n2) {
        strcpy(arr[k], R[j]);
        j++;
        k++;
    }
}

void mergeSort(char arr[][PANJANG_KATA], int left, int right) {

    if(left < right) {

        int mid = (left + right) / 2;

        mergeSort(arr, left, mid);
        mergeSort(arr, mid + 1, right);

        merge(arr, left, mid, right);
    }
}

