#define SIZE 1000
#define MAX_WORDS 5000
#define PANJANG_KATA 100

// SWAP

void swapInt(int *a, int *b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}

void swapStr(char a[], char b[]) {
    char temp[PANJANG_KATA];
    strcpy(temp, a);
    strcpy(a, b);
    strcpy(b, temp);
}

// DISPLAY

void tampilInt(int arr[], int n) {
    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");
}

void tampilStr(char arr[][PANJANG_KATA], int n) {
    for(int i = 0; i < n; i++) {
        printf("%s\n", arr[i]);
    }
}

// SHUFFLE

void shuffleInt(int arr[], int n) {
    for(int i = 0; i < n; i++) {
int j = rand() % n;
        swapInt(&arr[i], &arr[j]);
    }
}

void shuffleStr(char arr[][PANJANG_KATA], int n) {
    for(int i = 0; i < n; i++) {
        int j = rand() % n;
        swapStr(arr[i], arr[j]);
    }
}

// Bubble Sort
void bubbleSort(int arr[], int n) {
    for(int i = 0; i < n - 1; i++) {
        for(int j = 0; j < n - i - 1; j++) {
            if(arr[j] > arr[j + 1]) {
                swapInt(&arr[j], &arr[j + 1]);
            }
        }
    }
}

// Insertion Sort
void insertionSort(int arr[], int n) {
    for(int i = 1; i < n; i++) {

        int key = arr[i];
        int j = i - 1;

        while(j >= 0 && arr[j] > key) {
            arr[j + 1] = arr[j];
            j--;
        }

        arr[j + 1] = key;
    }
}

// Selection Sort
void selectionSort(int arr[], int n) {
    for(int i = 0; i < n - 1; i++) {

 int min = i;

        for(int j = i + 1; j < n; j++) {
            if(arr[j] < arr[min]) {
                min = j;
            }
        }

        swapInt(&arr[i], &arr[min]);
    }
}

// MERGE SORT

void merge(char arr[][PANJANG_KATA], int left, int mid, int right) {

    int n1 = mid - left + 1;
    int n2 = right - mid;

    char L[n1][PANJANG_KATA];
    char R[n2][PANJANG_KATA];

    for(int i = 0; i < n1; i++) {
        strcpy(L[i], arr[left + i]);
    }

    for(int j = 0; j < n2; j++) {
        strcpy(R[j], arr[mid + 1 + j]);
    }

    int i = 0;
    int j = 0;
    int k = left;

    while(i < n1 && j < n2) {

        if(strcmp(L[i], R[j]) <= 0) {
            strcpy(arr[k], L[i]);
            i++;
        } else {
            strcpy(arr[k], R[j]);
            j++;
        }

        k++;
    }

    while(i < n1) {
        strcpy(arr[k], L[i]);
        i++;
        k++;
    }

    while(j < n2) {
        strcpy(arr[k], R[j]);
        j++;
        k++;
    }
}

void mergeSort(char arr[][PANJANG_KATA], int left, int right) {

    if(left < right) {

        int mid = (left + right) / 2;

        mergeSort(arr, left, mid);
        mergeSort(arr, mid + 1, right);

        merge(arr, left, mid, right);
    }
}

// QUICK SORT

int partition(char arr[][PANJANG_KATA], int low, int high) {

    char pivot[PANJANG_KATA];
    strcpy(pivot, arr[high]);

    int i = low - 1;

    for(int j = low; j < high; j++) {

        if(strcmp(arr[j], pivot) < 0) {

i++;
            swapStr(arr[i], arr[j]);
        }
    }

    swapStr(arr[i + 1], arr[high]);

    return i + 1;
}

void quickSort(char arr[][PANJANG_KATA], int low, int high) {

    if(low < high) {

        int pi = partition(arr, low, high);

        quickSort(arr, low, pi - 1);
        quickSort(arr, pi + 1, high);
    }
}

// SHELL SORT

void shellSort(char arr[][PANJANG_KATA], int n) {

    for(int gap = n / 2; gap > 0; gap /= 2) {

        for(int i = gap; i < n; i++) {

            char temp[PANJANG_KATA];
            strcpy(temp, arr[i]);

            int j;

            for(j = i; j >= gap && strcmp(arr[j - gap], temp) > 0; j -= gap) {
                strcpy(arr[j], arr[j - gap]);
            }

            strcpy(arr[j], temp);
        }
    }
}

